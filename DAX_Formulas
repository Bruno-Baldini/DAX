Moving Average Time Period= 
--Questa misura calcola una media mobile a 30 giorni delle vendite

VAR LastTransactionDate = MAx('Calendar'[Transaction_Date]) -- Prende la data più recente nel contesto corrente (ad esempio, se stai guardando il mese di marzo, prende il 31 marzo).
VAR AverageDays = 30 -- Definisce la finestra temporale della media mobile (Mensile)
VAR Period =
FILTER( -- Rappresenta la finestra temporale

    ALL('Calendar'[Transaction_Date]), -- Si rimuove ogni filtro presente nella tabella Calendar sulla colonna Transaction_Date

    AND( -- Per ogni data presente nella tabella Calendar, si seleziona un intervallo di 30 giorni tra (LastTransactionDate - 30) fino a LastTransactionDate

        'Calendar'[Transaction_Date] > LastTransactionDate - AverageDays,
        'Calendar'[Transaction_Date] <= LastTransactionDate
    )
)
VAR Output = 
CALCULATE(
    AVERAGEX(
        'Calendar',
        [Customer Sales]
    ),
    Period
) -- Ogni punto del grafico/tabella mostrerà la media delle vendite dei 30 giorni precedenti a quella data, utile per smussare le fluttuazioni e vedere il trend generale.

RETURN
Output

-- VERSIONE Mensile, Periodo di 3 Mesi
Media Mobile 3M =
VAR UltimaData = LASTDATE(Calendario[Data]) --L'ultima data corrente disponibile, come MAX()
VAR Finestra =
    DATESINPERIOD( -- Si definisce una finestra temporale
        Calendario[Data],
        UltimaData, -- Dall'ultima data disponibile, si torna indietro di 3 Mesi. Si Crea un periodo tra (UltimaData - 3) e UltimaData
        -3,
        MONTH                   
    )
RETURN
    CALCULATE(
        AVERAGEX(
            VALUES(Calendario[Anno] & Calendario[Mese]),  -- Torna una tabella Calendario can valori unici su Anno e Mese
            [Fatturato Totale]
        ),
        Finestra
    )


