% Totale Selezionato (ALLSELECTED)=
DIVIDE(
    SUM(Vendite[Importo]), -- calcolo dele venditre totali effettuate in base al contesto di riga (di uno specifico prodotto)
    CALCULATE( - si crea il denominatore
        SUM(
            Vendite[Importo] -- calcolo delle vendite
          ), 
        ALLSELECTED(Vendite[prodotto])  -- non si considerano le vendite dei singoli prodotti, ma quelle delle categorie, in modo da ottenere la percentuale dei pordotti venduti a seconda della categoria di appartenenza
    )
)

Ranking Selezionato =
